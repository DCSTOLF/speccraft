{
  "name": "speccraft-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "stable",
      "profile": "minimal"
    }
  },

  // Named volume keeps ~/.claude (OAuth token, settings, session history)
  // across rebuilds. ${devcontainerId} scopes it per-project so multiple
  // speccraft checkouts don't share auth state.
  // SECURITY: do NOT bind-mount the host's ~/.claude. See:
  // https://code.claude.com/docs/en/devcontainer
  "mounts": [
    "source=speccraft-claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
  ],

  "containerEnv": {
    // Skip telemetry from the dev environment.
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",

    // speccraft dev knobs.
    "SPECCRAFT_LOG_LEVEL": "debug"
  },

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "anthropic.claude-code"
      ],
      "settings": {
        "go.toolsManagement.autoUpdate": false,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Useful when iterating on the plugin: rebuild binaries on every container
  // start (cheap; <2s if cache is warm).
  "postStartCommand": "bash scripts/install-binaries.sh || true",

  // Forward nothing by default. Speccraft has no network services.
  "forwardPorts": [],

  // Workspace mount. Default behavior is fine; documented here for clarity.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/speccraft,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/speccraft"
}
